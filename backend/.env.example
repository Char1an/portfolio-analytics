# Backend environment variables.
# Copy to backend/.env for local dev, or set in the Render dashboard for prod.

# Required in non-dev environments. Generate a random 32-char string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PORTFOLIO_SECRET=

# Comma-separated list of additional CORS origins (production frontend URLs).
# Local dev origins are always allowed by default.
# Example:
#   EXTRA_CORS_ORIGINS=https://folio-klarity.vercel.app,https://folioklarity.com
EXTRA_CORS_ORIGINS=

# Environment marker. "production" enforces the PORTFOLIO_SECRET requirement.
ENV=dev
