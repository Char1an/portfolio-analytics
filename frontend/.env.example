# Frontend environment variables.
# Copy to .env.local for local dev, or set in the Vercel dashboard for prod.

# URL of the deployed backend API (must include /api suffix).
# Leave blank for local dev — Vite proxies /api → http://localhost:8000.
# Example for prod:
#   VITE_API_URL=https://folio-klarity-api.onrender.com/api
VITE_API_URL=
